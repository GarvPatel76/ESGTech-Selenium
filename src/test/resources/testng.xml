<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ESG Tech Automation Suite" parallel="tests" thread-count="3">

    <!-- Chrome Execution -->
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.GHGTest"/>
            <class name="tests.WaterTest"/>
            <class name="tests.WasteTest"/>
            <class name="tests.ProfileTest"/>
            <class name="tests.ReportExportTest"/>
        </classes>
    </test>

    <!-- Firefox Execution -->
    <test name="Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.GHGTest"/>
            <class name="tests.WaterTest"/>
            <class name="tests.WasteTest"/>
            <class name="tests.ProfileTest"/>
            <class name="tests.ReportExportTest"/>
        </classes>
    </test>

    <!-- Edge Execution -->
    <test name="Edge Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.GHGTest"/>
            <class name="tests.WaterTest"/>
            <class name="tests.WasteTest"/>
            <class name="tests.ProfileTest"/>
            <class name="tests.ReportExportTest"/>
        </classes>
    </test>

</suite>
