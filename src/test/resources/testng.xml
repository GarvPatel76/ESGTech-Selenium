<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ESG Tech Automation Suite" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="utils.TestListener" />
    </listeners>

    <!-- Chrome Execution -->
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.NavigationTest"/>
            <class name="tests.FormTest"/>
            <class name="tests.SearchTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.SecurityUITest"/>
            <class name="tests.UITest"/>
            <class name="tests.PerformanceTest"/>
            <class name="tests.LogoutTest"/>
        </classes>
    </test>

    <!-- Firefox Execution -->
    <test name="Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.NavigationTest"/>
            <class name="tests.FormTest"/>
            <class name="tests.SearchTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.SecurityUITest"/>
            <class name="tests.UITest"/>
            <class name="tests.PerformanceTest"/>
            <class name="tests.LogoutTest"/>
        </classes>
    </test>

    <!-- Edge Execution -->
    <test name="Edge Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.NavigationTest"/>
            <class name="tests.FormTest"/>
            <class name="tests.SearchTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.SecurityUITest"/>
            <class name="tests.UITest"/>
            <class name="tests.PerformanceTest"/>
            <class name="tests.LogoutTest"/>
        </classes>
    </test>

</suite>
